# Swiss Post - Security .htaccess
# Prevent direct access to sensitive files and directories

# Enable mod_rewrite
RewriteEngine On

# Set the RewriteBase
RewriteBase /

# Block access to hidden files and directories (starting with .)
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to sensitive file types
<FilesMatch "\.(log|txt|md|ini|conf|json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow robots.txt
<Files "robots.txt">
    Order allow,deny
    Allow from all
</Files>

# Block direct access to /home directory listing
Options -Indexes

# Block direct access to PHP files in /home (except through index.php router)
# Allow callback.php for Telegram webhook
RewriteCond %{REQUEST_URI} ^/home/.*\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/home/callback\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/home/admin/admin\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/home/setup_webhook\.php$ [NC]
RewriteCond %{THE_REQUEST} !index\.php [NC]
RewriteRule ^ - [F,L]

# Block access to logs directory
RewriteRule ^home/logs/ - [F,L]

# Block access to status directory
RewriteRule ^home/status/ - [F,L]

# Block access to lib directory
RewriteRule ^lib/ - [F,L]

# Block access to config.php directly
RewriteRule ^config\.php$ - [F,L]

# Block PHP files in sensitive directories
<Directory "home/logs">
    Order allow,deny
    Deny from all
</Directory>

<Directory "home/status">
    Order allow,deny
    Deny from all
</Directory>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Prevent access to sensitive files
<FilesMatch "(^#.*#|\.(bak|config|dist|fla|inc|ini|log|psd|sh|sql|sw[op])|~)$">
    Order allow,deny
    Deny from all
    Satisfy All
</FilesMatch>

# Error pages
ErrorDocument 403 /index.php?s=e&r=forbidden
ErrorDocument 404 /index.php?s=e&r=notfound
